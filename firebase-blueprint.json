{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Represents an enterprise order or booking from a garments/factory customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "factoryName": { "type": "string" },
        "buyerName": { "type": "string" },
        "poNumber": { "type": "string" },
        "styleNumber": { "type": "string" },
        "itemName": { "type": "string" },
        "ref": { "type": "string" },
        "unit": { "type": "string" },
        "unitPrice": { "type": "number" },
        "details": { "type": "string" },
        "sizeWise": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "factoryName", "buyerName", "poNumber", "styleNumber", "itemName", "unitPrice", "unit", "createdAt"]
    },
    "ProformaInvoice": {
      "title": "ProformaInvoice",
      "description": "Represents a proforma invoice issued to a client.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNo": { "type": "string" },
        "factoryName": { "type": "string" },
        "buyerName": { "type": "string" },
        "ref": { "type": "string" },
        "date": { "type": "string" },
        "hsCode": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "invoiceNo", "factoryName", "buyerName", "date", "createdAt"]
    },
    "UserAccount": {
      "title": "UserAccount",
      "description": "Admin created user credentials and permissions map.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "passwordHash": { "type": "string" },
        "allowedTabs": { "type": "array" },
        "writeAccess": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "email", "passwordHash", "allowedTabs", "writeAccess", "createdAt"]
    },
    "DatabaseHostingConfig": {
      "title": "DatabaseHostingConfig",
      "description": "Administrative Database and web hosting coordinates.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "appName": { "type": "string" },
        "liveAppUrl": { "type": "string" },
        "dbHost": { "type": "string" },
        "dbName": { "type": "string" },
        "dbUser": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "appName", "liveAppUrl", "dbHost", "dbName", "dbUser", "updatedAt"]
    }
  },
  "firestore": {
    "/erp_company_data/shared_workspace/{collectionName}/{docId}": {
      "schema": "Booking",
      "description": "Shared real-time enterprise workspace data (including bookings, pis, challans, banks, suppliers, work_orders, sup_payments, conveyances, products, manual_bills, jobcards, commercial_invoices)"
    },
    "/users/{userId}/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Cloud synced collections of bookings per user"
    },
    "/users/{userId}/pis/{piId}": {
      "schema": "ProformaInvoice",
      "description": "Cloud synced collections of proforma invoices per user"
    }
  }
}
