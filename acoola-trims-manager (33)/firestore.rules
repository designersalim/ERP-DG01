rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserEmail() {
      return request.auth.token.email;
    }

    function isMasterAdmin() {
      return isSignedIn() && getUserEmail() == 'salim@ayra.com';
    }

    function isAuthorizedOperator() {
      return isSignedIn() && (
        isMasterAdmin() ||
        exists(/databases/$(database)/documents/erp_company_data/shared_workspace/user_accounts/$(getUserEmail()))
      );
    }

    function getOperatorData() {
      return get(/databases/$(database)/documents/erp_company_data/shared_workspace/user_accounts/$(getUserEmail())).data;
    }

    function hasTabAccess(tabName) {
      return isMasterAdmin() || (
        isAuthorizedOperator() && 
        tabName in getOperatorData().allowedTabs
      );
    }

    function hasWriteAccess(tabName) {
      return isMasterAdmin() || (
        isAuthorizedOperator() && 
        tabName in getOperatorData().writeAccess && 
        getOperatorData().writeAccess[tabName] == true
      );
    }

    // 2. Erp Company Data Rules
    // Operator accounts are read-only for any logged-in user to check login details, but write-only for master admin
    match /erp_company_data/shared_workspace/user_accounts/{docId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }

    // Individual collection rules within erp_company_data for operators
    match /erp_company_data/shared_workspace/bookings/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('bookings');
    }
    match /erp_company_data/shared_workspace/pis/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('pis');
    }
    match /erp_company_data/shared_workspace/challans/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('challans');
    }
    match /erp_company_data/shared_workspace/banks/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('banks');
    }
    match /erp_company_data/shared_workspace/suppliers/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('suppliers');
    }
    match /erp_company_data/shared_workspace/work_orders/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('work_orders');
    }
    match /erp_company_data/shared_workspace/sup_payments/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('sup_payments');
    }
    match /erp_company_data/shared_workspace/conveyances/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('conveyances');
    }
    match /erp_company_data/shared_workspace/products/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('products-catalogue');
    }
    match /erp_company_data/shared_workspace/manual_bills/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('invoice-bill');
    }
    match /erp_company_data/shared_workspace/jobcards/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('job-cards');
    }
    match /erp_company_data/shared_workspace/commercial_invoices/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('commercial-invoices');
    }
    match /erp_company_data/shared_workspace/db_configs/{docId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }
    match /erp_company_data/shared_workspace/quotations/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('quote-builder');
    }
    match /erp_company_data/shared_workspace/lc_history/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('lc-documents');
    }
    match /erp_company_data/shared_workspace/buyer_payments/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('party-ledger');
    }
    match /erp_company_data/shared_workspace/employees/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('payroll');
    }
    match /erp_company_data/shared_workspace/payrolls/{docId} {
      allow read: if isAuthorizedOperator();
      allow write: if hasWriteAccess('payroll');
    }
    match /erp_company_data/shared_workspace/registered_clients/{docId} {
      allow read, write: if isSignedIn();
    }
    match /erp_company_data/shared_workspace/website_pages/{docId} {
      allow read: if true; // Publicly accessible to render website
      allow write: if isMasterAdmin();
    }

    // 3. Only authenticated users can read or write their own namespace (backwards compatibility)
    match /users/{userId}/{collectionName}/{docId=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
